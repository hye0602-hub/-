rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }

    function isValidMission(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'sleepAt', 'wakeupAt', 'missionType', 'intensity', 'durationHours', 'score', 'aiFeedback']) &&
             data.keys().size() == 9 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.sleepAt is string &&
             data.wakeupAt is string &&
             data.missionType is string &&
             data.intensity is string &&
             data.durationHours is number &&
             data.score is number &&
             data.aiFeedback is string;
    }

    function isValidAlarm(data) {
      return data.userId == request.auth.uid &&
             data.time is string &&
             data.days is list &&
             data.isEnabled is bool &&
             data.missionType is string &&
             data.intensity is string &&
             data.volume is number &&
             data.isStormAlarm is bool &&
             data.createdAt is timestamp;
    }

    function isValidSleepSession(data) {
      return data.userId == request.auth.uid &&
             (data.startTime is timestamp || data.startTime == null) &&
             data.createdAt is timestamp;
    }

    match /missions/{missionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidMission(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidMission(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /alarms/{alarmId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAlarm(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidAlarm(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /sleep_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(sessionId) && isValidSleepSession(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(sessionId) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().startTime == existing().startTime &&
        incoming().diff(existing()).affectedKeys().hasOnly(['endTime', 'durationHours', 'score', 'aiFeedback'])
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
